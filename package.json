{
  "name": "jims-roulette",
  "productName": "Jims Roulette",
  "private": true,
  "version": "0.2.0",
  "description": "Jims Roulette desktop game and self-updating launcher",
  "author": "Ltaylor809",
  "main": "electron/main.mjs",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "start": "node server/index.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "assets": "node scripts/download-assets.mjs",
    "firebase:serve": "pnpm build && firebase emulators:start --only hosting,firestore,auth",
    "firebase:deploy": "pnpm build && firebase deploy --only hosting,firestore:rules",
    "electron:dev": "pnpm build && electron electron/main.mjs",
    "electron:pack": "pnpm build && electron-builder --dir",
    "electron:dist": "pnpm build && electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "firebase": "^12.16.0",
    "three": "^0.178.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.15",
    "@types/three": "^0.178.1",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "firebase-tools": "^15.24.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.5",
    "vitest": "^3.2.4"
  },
  "build": {
    "appId": "com.ltaylor.jimsroulette",
    "productName": "Jims Roulette",
    "electronDist": "node_modules/electron/dist",
    "artifactName": "Jims-Roulette-${version}-${os}-${arch}.${ext}",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.games",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "category": "Game",
      "target": "AppImage"
    },
    "publish": {
      "provider": "github",
      "owner": "Ltaylor809",
      "repo": "jims-roulette",
      "releaseType": "release"
    }
  }
}
